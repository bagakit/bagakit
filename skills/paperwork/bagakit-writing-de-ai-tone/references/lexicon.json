    {"term": "foster", "tier": "density", "lint": true, "suggestions": ["encourage"]},
    {"term": "elevate", "tier": "density", "lint": true, "suggestions": ["improve"]},
    {"term": "empower", "tier": "density", "lint": true, "suggestions": ["enable"]},
