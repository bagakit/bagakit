# Keep local scratch files out of commits.
*.swp
*.tmp
.tmp/
.DS_Store
# Ignore first-level docs-local scratch directories.
docs/.*/
site/
dist/
dist_*/
.dist-*
node_modules/
# Bagakit runtime state is host-local and may contain private task, research,
# selector, evolver, or design context. Public evidence must be promoted to
# docs/, mem/, gate_validation/, gate_eval/, or skills/ before it is committed.
.bagakit/
mem/
!mem/
mem/*
!mem/README.md
!mem/migration/
!mem/migration/**
!mem/decisions/
!mem/decisions/**
!mem/brainstorm-memory-quality/
!mem/brainstorm-memory-quality/**
.codex
__pycache__
.mem_inbox
